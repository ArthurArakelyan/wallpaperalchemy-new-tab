{
  "manifest_version": 3,
  "name": "Wallpaper Alchemy – New Tab",
  "version": "PLACEHOLDER",
  "description": "A beautiful, customizable New Tab page with backgrounds and widgets.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "32": "icons/32.png",
    "48": "icons/48.png",
    "96": "icons/96.png",
    "128": "icons/128.png"
  },
  "permissions": [
    "storage",
    "search",
    "identity"
  ],
  "optional_permissions": [
    "bookmarks",
    "topSites"
  ],
  "background": {
    "service_worker": "service-worker.js"
  }
}
