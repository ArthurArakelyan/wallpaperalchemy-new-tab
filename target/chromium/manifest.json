{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "PLACEHOLDER",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "32": "icons/32.png",
    "48": "icons/48.png",
    "96": "icons/96.png",
    "128": "icons/128.png"
  },
  "permissions": [
    "storage",
    "search"
  ],
  "optional_permissions": [
    "bookmarks",
    "topSites"
  ],
  "background": {
    "service_worker": "service-worker.js"
  }
}
