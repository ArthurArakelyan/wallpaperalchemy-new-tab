{
  "manifest_version": 2,
  "name": "__MSG_extensionName__",
  "version": "PLACEHOLDER",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "new-tab@wallpaperalchemy",
      "strict_min_version": "58.0"
    }
  },
  "chrome_settings_overrides": {
    "homepage": "index.html"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "32": "icons/32.png",
    "48": "icons/48.png",
    "96": "icons/96.png",
    "128": "icons/128.png"
  },
  "permissions": [
    "storage",
    "search",
    "identity"
  ],
  "optional_permissions": [
    "bookmarks",
    "topSites"
  ]
}
